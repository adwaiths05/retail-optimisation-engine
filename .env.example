# --- 1. Database Configuration (Neon/Postgres) ---
# Use the standard postgresql:// protocol. 
# The application will programmatically handle +asyncpg for the API.
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# --- 2. Cache Configuration (Redis) ---
# For Local Dev: redis://localhost:6379/0
# For Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# --- 3. Security & Authentication ---
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_hex_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- 4. Application Settings ---
PROJECT_NAME="Retail Optimization Engine"
DEBUG=True
ENVIRONMENT=development

# --- 5. Frontend Configuration (For Streamlit) ---
# This is used by the frontend to locate the API
# For Local Dev: http://localhost:8000
# For Docker: http://api:8000
BACKEND_URL=http://localhost:8000

# --- 6. ML Model Paths (Optional Overrides) ---
# The system defaults to /app/models/ in Docker, but you can override here
# MODEL_PATH=models/user_tower_quant.onnx
# RERANKER_PATH=models/reranker_xgb.pkl